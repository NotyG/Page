from math import inf
n, k = map(int, input().split())
a = list(map(int, input().split()))
s = [0]* (n+1)
for i in range(1, n+1):
    s[i] += s[i-1]+a[i-1]
pref = [0]*(n+1)
for i in range(k, n+1):
    pref[i] = max(pref[i-1], s[i] - s[i-k])
suf = [0]*(n+2) #костыль
for i in range(n+1-k, 0, -1):
    suf[i] = max(suf[i+1], s[i+k-1] - s[i-1])
ans = inf
for i in range(1, n+1-k+1):
    ans = min(ans, max(pref[i-1], suf[i+k]))
print(an)