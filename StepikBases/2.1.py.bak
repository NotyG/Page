class Point():
    def __init__(self, x, type):
        self.x = x
        self.type = type
L, R = map(int, input().split())
n = int(input())
points = []
for i in range(n):
    x1, x2 = map(int,input().split())
    points.append(Point(x1, 1))
    points.append(Point(x2, -1))
points.sort(key=lambda point: point.x)
state = 0
startI = None
for i in range(n):
    state += points[i].type
    if points[i].x <= L:
        startI = i 
ans = 'YES'
for i in range(startI, n):
    state += points[i].type
    if state <= 0 and points[i].x < R:
        ans = 'NO'
    if points[i].x >= R:
        break
print(ans)